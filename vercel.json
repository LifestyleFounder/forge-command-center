    }
  ],
  "functions": {
    "api/scrape-creators.js": {
      "maxDuration": 60
    },
    "api/analyze-posts.js": {
      "maxDuration": 60
    },
    "api/content-gameplan.js": {
      "maxDuration": 60
    },
    "api/daily-ideas.js": {
      "maxDuration": 60
    },
    "api/content-analytics.js": {
      "maxDuration": 60
    },
    "api/youtube-stats.js": {
